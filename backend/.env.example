# Copy to .env and fill in. .env is gitignored — never commit real tokens.
# See SETUP.md for click-by-click instructions on getting each value.

# --- Anthropic (the brain) ---
ANTHROPIC_API_KEY=

# --- Slack (Socket Mode) ---
SLACK_BOT_TOKEN=        # xoxb-...  (OAuth & Permissions → Bot User OAuth Token)
SLACK_APP_TOKEN=        # xapp-...  (Socket Mode → App-Level Token, scope connections:write)
SLACK_SIGNING_SECRET=   # Basic Information → Signing Secret (optional in Socket Mode)

# --- Model (optional) ---
JARVIS_MODEL=sonnet     # sonnet | opus | haiku  (orchestrator model; defaults to sonnet)

# --- Knowledge base (optional) ---
# Root folder of the per-project Obsidian vaults. Defaults to ../vault (the repo's vault/).
VAULT_DIR=../vault
